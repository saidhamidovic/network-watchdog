# Configuration for Security Guardian
# Copy this to .env and fill in your values

# ntfy.sh topic for notifications
NTFY_TOPIC=your-secret-topic-here

# Gateway IP for ARP monitoring
GATEWAY_IP=192.168.0.1

# Interval between ARP checks in seconds
ARP_INTERVAL=60

# Log paths (mapped inside the container)
AUTH_LOG=/var/log/auth.log
FAIL2BAN_LOG=/var/log/fail2ban.log
SECURITY_LOG=/var/log/securityguardian.log
