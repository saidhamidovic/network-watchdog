# Configuration for Network Watchdog
# Copy this to .env and fill in your values

# Network range to scan (e.g., 192.168.1.0/24)
SCAN_TARGETS=192.168.0.0/24

# Interval between scans in seconds (e.g., 28800 for 8 hours)
SCAN_INTERVAL=28800

# ntfy.sh topic for notifications
NTFY_TOPIC=your-secret-topic-here
