# --- Network Scanning ---
SCAN_TARGETS=192.168.0.0/24
SCAN_INTERVAL=28800

# --- Notifications ---
NTFY_TOPIC=my_secret_watchdog_topic

# --- ARP Monitoring ---
GATEWAY_IP=192.168.0.1
ARP_INTERVAL=60

# --- Log Paths (inside container) ---
AUTH_LOG=/var/log/auth.log
FAIL2BAN_LOG=/var/log/fail2ban.log
SECURITY_LOG=/var/log/securityguardian.log
